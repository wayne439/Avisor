{
    "compilerOptions": {
          "target": "ES2022",
          "module": "ESNext",
          "moduleResolution": "bundler",
          "strict": true,
          "skipLibCheck": true,
          "noEmit": true,
          "resolveJsonModule": true,
          "lib": ["ES2022", "DOM", "DOM.Iterable"]
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "*.ts"]
}
